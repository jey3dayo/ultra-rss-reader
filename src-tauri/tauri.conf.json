{
  "$schema": "https://raw.githubusercontent.com/niccokunzmann/tauri/tauri-v2.5.0/crates/tauri-cli/schema.json",
  "productName": "Ultra RSS Reader",
  "version": "0.5.0",
  "identifier": "com.ultra-rss-reader.dev",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https: http:; frame-src https: http:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jey3dayo/ultra-rss-reader/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBNkQxMTFDNkM4ODM1MwpSV1JUZzhqR0VkR21CeU5RV2p1U3lqRE4rV3dhaittVkNVT25GWTV2OXFTcWxLRVRvYjBvOVhCYgo="
    }
  }
}
