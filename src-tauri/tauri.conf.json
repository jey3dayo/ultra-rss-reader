{
  "$schema": "https://raw.githubusercontent.com/niccokunzmann/tauri/tauri-v2.5.0/crates/tauri-cli/schema.json",
  "productName": "Ultra RSS Reader",
  "version": "0.1.0",
  "identifier": "com.ultra-rss-reader.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ultra RSS Reader",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "opener": {
      "openUrl": {
        "enabled": true
      }
    }
  }
}
