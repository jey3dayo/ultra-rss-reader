# Tauri auto-generated ACL schemas (large minified JSON, suppress diff noise)
src-tauri/gen/schemas/*.json binary

# Lock files — hide from GitHub PR diffs but keep text merge
src-tauri/Cargo.lock linguist-generated=true

# Keep GitHub workflow/config YAML on LF so Windows yamllint matches CI expectations
*.yml text eol=lf
*.yaml text eol=lf
